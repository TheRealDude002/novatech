# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb_connection_string

# JWT
JWT_SECRET=replace-with-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_UPLOAD=5242880
